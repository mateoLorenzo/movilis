{
  "name": "movilis",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "mobile": "pnpm --filter @movilis/mobile start",
    "mobile:ios": "pnpm --filter @movilis/mobile ios",
    "mobile:android": "pnpm --filter @movilis/mobile android",
    "mobile:web": "pnpm --filter @movilis/mobile web",
    "back": "pnpm --filter @carpooling/back start",
    "back:dev": "pnpm --filter @carpooling/back dev",
    "db:generate": "pnpm --filter @carpooling/db generate",
    "db:migrate": "pnpm --filter @carpooling/db migrate"
  },
  "packageManager": "pnpm@11.0.9"
}
