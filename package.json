{
  "name": "movilis",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace @movilis/mobile",
    "mobile:ios": "npm run ios --workspace @movilis/mobile",
    "mobile:android": "npm run android --workspace @movilis/mobile",
    "mobile:web": "npm run web --workspace @movilis/mobile",
    "back": "npm run start --workspace @carpooling/back",
    "back:dev": "npm run dev --workspace @carpooling/back",
    "db:generate": "npm run generate --workspace @carpooling/db -- --name=$npm_config_name",
    "db:migrate": "npm run migrate --workspace @carpooling/db"
  }
}
