DATABASE_URL=postgres://postgres:postgres@localhost:5432/carpooling
JWT_SECRET=replace-with-a-long-random-secret

# Optional auth TTL overrides, in seconds.
# ACCESS_TOKEN_TTL_SECONDS=900
# REFRESH_TOKEN_TTL_SECONDS=2592000
# OTP_TTL_SECONDS=600

# Local/dev only: include OTP codes in /auth/request-otp responses.
# AUTH_EXPOSE_DEV_OTP_CODE=true
